DATABASE_URL=postgresql://hackonomics:password@localhost:5432/hackonomics
JWKS_URL=http://central-auth:8081/.well-known/jwks.json
JWT_ISSUER=http://central-auth:8081
JWT_AUDIENCE=hackonomics-api
GEMINI_API_KEY=your-gemini-api-key
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=business_news
INTERNAL_AI_TOKEN=change-me-internal-token
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/calendar/oauth/callback/
# Redis (shared with Kotlin — same instance)
REDIS_URL=redis://redis:6380/0
# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_NEWS_REFRESH_REQUEST_TOPIC=news.refresh.request
KAFKA_NEWS_REFRESH_RESULT_TOPIC=news.refresh.result
KAFKA_CONSUMER_GROUP_ID=hackonomics-fastapi-news
# gRPC server port (internal only)
GRPC_PORT=50052
